# Pharos Shield configuration
#
# Network selection: "mainnet" (default, chain 1672) or "testnet" (Atlantic, 688689).
# Mainnet is the default and the network every example/demo in this repo is run on.
PHAROS_NETWORK=mainnet

# Optional RPC overrides. If unset, Shield uses the verified built-in defaults
# (see scripts/config.ts). The default mainnet RPC (https://rpc.pharos.xyz) was
# confirmed to expose the debug_* trace namespace with callTracer.
# PHAROS_MAINNET_RPC=https://rpc.pharos.xyz
# PHAROS_TESTNET_RPC=https://atlantic.dplabs-internal.com

# Optional independent RPC peers for canonical-block quorum checks. Comma-separated.
# The primary RPC above is included automatically. With one endpoint Shield labels
# results "single-endpoint"; it never pretends that one endpoint is a quorum.
# PHAROS_RPC_QUORUM_URLS=https://second.example,https://third.example
# PHAROS_RPC_QUORUM_MIN=2

# Latest-state commands run this many blocks behind the slowest healthy RPC tip.
# Historical blocks report whether they meet this local confirmation policy.
# PHAROS_FINALITY_CONFIRMATIONS=2

# Refuse analysis when healthy RPC tip heights differ by more than this amount.
# PHAROS_RPC_MAX_TIP_SKEW=5

# Request timeout in milliseconds (default 20000).
# PHAROS_RPC_TIMEOUT_MS=20000

# Reject a latest block older than this many seconds (mainnet default: 300).
# PHAROS_MAX_BLOCK_AGE_SECONDS=300

# Optional genesis override. Mainnet's verified genesis hash is built in.
# PHAROS_GENESIS_HASH=0x...

# Optional evidence signer. This MUST be a separate key used only to attest
# read-only evidence; never reuse a wallet/transaction private key.
# PHAROS_EVIDENCE_SIGNING_KEY=0x...

# HTTP MCP defaults to 127.0.0.1. A non-loopback host REQUIRES a bearer token.
# PHAROS_SHIELD_HTTP_HOST=127.0.0.1
# PHAROS_SHIELD_HTTP_TOKEN=replace-with-a-long-random-secret
# PHAROS_SHIELD_HTTP_MAX_SESSIONS=32
# PHAROS_SHIELD_HTTP_SESSION_IDLE_MS=900000
