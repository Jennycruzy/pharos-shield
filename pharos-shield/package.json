{
  "name": "pharos-shield-mcp",
  "version": "0.1.0",
  "description": "Transaction & contract integrity layer for Pharos mainnet: simulate, autopsy, inspect. Real on-chain facts, no mocks.",
  "type": "module",
  "bin": {
    "pharos-shield": "dist/scripts/cli.js",
    "pharos-shield-mcp": "dist/mcp/server.js"
  },
  "files": [
    "dist/scripts",
    "dist/mcp",
    "scripts/connect.mjs",
    "SKILL.md",
    "AGENTS.md",
    "CLAUDE.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:mcp",
    "test:unit": "node --import tsx --test tests/unit/*.test.ts",
    "test:mcp": "node --import tsx --test tests/mcp/*.test.ts",
    "test:live": "node --import tsx --test tests/integration/*.test.ts",
    "cli": "node --import tsx scripts/cli.ts",
    "mcp": "node --import tsx mcp/server.ts",
    "mcp:http": "node --import tsx mcp/server.ts --http",
    "setup": "node scripts/connect.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "ethers": "^6.13.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "fast-check": "4.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "ws": "^8.20.1"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
